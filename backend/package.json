    "jsonwebtoken": "^9.0.0",
    "pino": "^8.0.0",
    "@prisma/client": "^5.0.0",
    "googleapis": "^128.0.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "prisma": "^5.0.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/bcryptjs": "^2.4.2",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.0.0"
