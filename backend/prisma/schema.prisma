generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String
  name          String?
  role          String         @default("USER")
  createdAt     DateTime       @default(now())
  googleAccount GoogleAccount?
}

model Employee {
  id            Int            @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String         @unique
  phoneNumber   String?
  niNumber      String? // National Insurance placeholder
  jobTitle      String?
  employeeType  String         @default("EMPLOYEE") // EMPLOYEE or DIRECTOR
  department    String?
  startDate     DateTime?
  endDate       DateTime?
  sponsorships  Sponsorship[]
  documents     Document[]
  timesheets    Timesheet[]
  leaveRequests LeaveRequest[]
}

model Sponsorship {
  id                   Int       @id @default(autoincrement())
  employee             Employee  @relation(fields: [employeeId], references: [id])
  employeeId           Int
  visaType             String
  casNumber            String? // Confirmation of acceptance for studies or CAS if relevant
  sponsorLicenseNumber String?
  startDate            DateTime
  endDate              DateTime?
  complianceNotes      String?
  active               Boolean   @default(true)
}

model Project {
  id          Int         @id @default(autoincrement())
  code        String      @unique
  name        String
  description String?
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  timesheets  Timesheet[]
}

model Timesheet {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId Int
  project    Project? @relation(fields: [projectId], references: [id])
  projectId  Int?
  date       DateTime
  hours      Float
  notes      String?
}

model LeaveRequest {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId Int
  type       String
  startDate  DateTime
  endDate    DateTime
  status     String   @default("PENDING")
  reason     String?
}

model Document {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId Int
  name       String
  path       String
  uploadedAt DateTime @default(now())
}

model GoogleAccount {
  id           Int       @id @default(autoincrement())
  user         User      @relation(fields: [userId], references: [id])
  userId       Int       @unique
  refreshToken String
  accessToken  String?
  scope        String?
  expiry       DateTime?
  createdAt    DateTime  @default(now())
}
