generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String
  name          String?
  role          String         @default("USER")
  employeeId    Int?           @unique
  employee      Employee?      @relation(fields: [employeeId], references: [id])
  createdAt     DateTime       @default(now())
  googleAccount GoogleAccount?
}

model Employee {
  id           Int       @id @default(autoincrement())
  firstName    String
  middleName   String?
  lastName     String
  title        String? // Mr, Mrs, Dr, etc.
  gender       String?
  ethnicity    String?
  dateOfBirth  DateTime?
  email        String    @unique
  phoneNumber  String?
  workPhone    String?
  niNumber     String? // National Insurance placeholder
  jobTitle     String?
  employeeType String    @default("EMPLOYEE") // EMPLOYEE or DIRECTOR
  department   String?
  startDate    DateTime?
  endDate      DateTime?
  probationEndDate DateTime?

  // Address Details
  address1 String?
  address2 String?
  address3 String?
  townCity String?
  county   String?
  postcode String?

  // Bank Details
  accountName   String?
  bankName      String?
  bankBranch    String?
  accountNumber String?
  sortCode      String?

  // Salary Details
  salary              Float?
  salaryRate          String?
  paymentFrequency    String?
  salaryEffectiveFrom DateTime?
  salaryReason        String?
  payrollNumber       String?

  // Sensitive Identity and Eligibility Details
  taxCode               String?
  passportNumber        String?
  passportCountryOfIssue String?
  passportExpiryDate    DateTime?
  licenceNumber         String?
  licenceCountryOfIssue String?
  licenceClass          String?
  licenceExpiryDate     DateTime?
  visaNumber            String?
  visaExpiryDate        DateTime?

  // Emergency Contact Information
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  emergencyContactAddress  String?

  user          User?
  sponsorships  Sponsorship[]
  documents     Document[]
  timesheets    Timesheet[]
  leaveRequests LeaveRequest[]
}

model Sponsorship {
  id                   Int                             @id @default(autoincrement())
  employee             Employee                        @relation(fields: [employeeId], references: [id])
  employeeId           Int
  visaType             String
  casNumber            String? // Confirmation of acceptance for studies or CAS if relevant
  sponsorLicenseNumber String?
  startDate            DateTime
  endDate              DateTime?
  complianceNotes      String?
  active               Boolean                         @default(true)
  complianceEvidence   SponsorshipComplianceEvidence[]
  reportableEvents     SponsorshipReportableEvent[]
}

model SponsorshipComplianceEvidence {
  id             Int          @id @default(autoincrement())
  sponsorship   Sponsorship  @relation(fields: [sponsorshipId], references: [id], onDelete: Cascade)
  sponsorshipId Int
  document      Document?    @relation(fields: [documentId], references: [id], onDelete: SetNull)
  documentId    Int?
  evidenceType  String
  notes         String?      @db.Text
  verifiedAt    DateTime?
  verifiedBy    Int?
  createdAt     DateTime     @default(now())
}

model SponsorshipReportableEvent {
  id            Int         @id @default(autoincrement())
  sponsorship   Sponsorship @relation(fields: [sponsorshipId], references: [id], onDelete: Cascade)
  sponsorshipId Int
  eventType     String
  eventDate     DateTime
  dueDate       DateTime
  status        String      @default("OPEN")
  notes         String?     @db.Text
  reportedAt    DateTime?
  reportedBy    Int?
  createdAt     DateTime    @default(now())
}

model Project {
  id          Int         @id @default(autoincrement())
  code        String      @unique
  name        String
  description String?
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  timesheets  Timesheet[]
}

model Timesheet {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId Int
  project    Project? @relation(fields: [projectId], references: [id])
  projectId  Int?
  date       DateTime
  hours      Float
  notes      String?
}

model LeaveRequest {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId Int
  type       String
  startDate  DateTime
  endDate    DateTime
  status     String   @default("PENDING")
  reason     String?
}

model Document {
  id                            Int                             @id @default(autoincrement())
  employee                      Employee                        @relation(fields: [employeeId], references: [id])
  employeeId                    Int
  name                          String
  path                          String
  type                          String? // Document type (e.g., CONTRACT, PASSPORT, etc.)
  shareToken                    String?                         @unique
  sharedAt                      DateTime?
  expiryDate                    DateTime? // Optional expiry date for documents
  uploadedAt                    DateTime                        @default(now())
  sponsorshipComplianceEvidence SponsorshipComplianceEvidence[]
}

model GoogleAccount {
  id           Int       @id @default(autoincrement())
  user         User      @relation(fields: [userId], references: [id])
  userId       Int       @unique
  refreshToken String
  accessToken  String?
  scope        String?
  expiry       DateTime?
  createdAt    DateTime  @default(now())
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  userEmail String?
  action    String // CREATE, READ, UPDATE, DELETE, LOGIN, EXPORT, etc.
  entity    String // Employee, Document, User, etc.
  entityId  Int?
  details   String?  @db.Text
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())
}

model DataConsent {
  id            Int       @id @default(autoincrement())
  employeeId    Int
  consentType   String // GDPR_PROCESSING, PRIVACY_NOTICE, etc.
  consentGiven  Boolean   @default(false)
  consentDate   DateTime?
  withdrawnDate DateTime?
  ipAddress     String?
  version       String? // Version of privacy policy
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
